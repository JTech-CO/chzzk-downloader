{
  "manifest_version": 3,
  "name": "Chzzk Downloader",
  "version": "2.1.1",
  "description": "치지직(Chzzk) VOD 및 클립을 원본 화질 MP4로 다운로드하는 확장 프로그램",
  "permissions": ["activeTab", "downloads"],
  "host_permissions": [
    "https://chzzk.naver.com/*",
    "https://api.chzzk.naver.com/*",
    "https://apis.naver.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chzzk.naver.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
